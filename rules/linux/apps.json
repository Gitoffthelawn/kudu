{
  "$schema": "../schema/rules.schema.json",
  "type": "apps",
  "apps": [
    { "id": "discord", "name": "Discord", "paths": ["${CONFIG}/discord/Cache/Cache_Data"] },
    { "id": "vscode", "name": "VS Code", "paths": ["${CONFIG}/Code/Cache/Cache_Data", "${CONFIG}/Code/CachedData"] },
    { "id": "slack", "name": "Slack", "paths": ["${CONFIG}/Slack/Cache/Cache_Data"] },
    { "id": "teams", "name": "Microsoft Teams", "paths": ["${CONFIG}/Microsoft/Microsoft Teams/Cache"] },
    { "id": "spotify", "name": "Spotify", "paths": ["${CACHE}/spotify"] },
    { "id": "npm", "name": "npm Cache", "paths": ["${HOME}/.npm/_cacache"] },
    { "id": "yarn", "name": "Yarn Cache", "paths": ["${CACHE}/yarn"] },
    { "id": "pip", "name": "pip Cache", "paths": ["${CACHE}/pip"] },
    { "id": "zoom", "name": "Zoom", "paths": ["${HOME}/.zoom/data/Cache", "${HOME}/.zoom/data/GPUCache", "${HOME}/.zoom/data/logs", "${HOME}/.zoom/logs"] },
    { "id": "telegram", "name": "Telegram", "paths": ["${LOCAL_SHARE}/TelegramDesktop/tdata/user_data", "${LOCAL_SHARE}/TelegramDesktop/tdata/emoji"] },
    { "id": "obs", "name": "OBS Studio", "paths": ["${CONFIG}/obs-studio/logs", "${CONFIG}/obs-studio/profiler_data"] },
    { "id": "jetbrains", "name": "JetBrains IDEs", "paths": ["${CACHE}/JetBrains"] },
    { "id": "pnpm", "name": "pnpm Store", "paths": ["${LOCAL_SHARE}/pnpm/store"] },
    { "id": "bun", "name": "Bun Cache", "paths": ["${HOME}/.bun/install/cache"] },
    { "id": "cargo", "name": "Cargo/Rust Cache", "paths": ["${HOME}/.cargo/registry/cache", "${HOME}/.cargo/registry/src"] },
    { "id": "go", "name": "Go Module Cache", "paths": ["${HOME}/go/pkg/mod/cache"] },
    { "id": "gradle", "name": "Gradle Cache", "paths": ["${HOME}/.gradle/caches", "${HOME}/.gradle/daemon"] },
    { "id": "maven", "name": "Maven Cache", "paths": ["${HOME}/.m2/repository"] },
    { "id": "composer", "name": "Composer Cache", "paths": ["${CACHE}/composer"] },
    { "id": "cursor", "name": "Cursor IDE", "paths": ["${CONFIG}/Cursor/Cache/Cache_Data", "${CONFIG}/Cursor/CachedData"] },
    { "id": "signal", "name": "Signal Desktop", "paths": ["${CONFIG}/Signal/Cache/Cache_Data"] },
    { "id": "postman", "name": "Postman", "paths": ["${CONFIG}/Postman/Cache/Cache_Data"] },
    { "id": "vlc", "name": "VLC", "paths": ["${CACHE}/vlc"] },
    { "id": "thunderbird", "name": "Thunderbird", "paths": ["${CACHE}/thunderbird"], "childSubdir": "cache2" },
    { "id": "gimp", "name": "GIMP", "paths": ["${CACHE}/gimp"] },
    { "id": "blender", "name": "Blender", "paths": ["${CACHE}/blender"] },
    { "id": "libreoffice", "name": "LibreOffice", "paths": ["${CACHE}/libreoffice"] },
    { "id": "teamviewer", "name": "TeamViewer", "paths": ["${HOME}/.teamviewer/logs", "${CACHE}/TeamViewer"] },
    { "id": "inkscape", "name": "Inkscape", "paths": ["${CACHE}/inkscape"] },
    { "id": "krita", "name": "Krita", "paths": ["${CACHE}/krita"] },
    { "id": "filezilla", "name": "FileZilla", "paths": ["${CACHE}/filezilla"] },
    { "id": "pidgin", "name": "Pidgin", "paths": ["${HOME}/.purple/icons"] },
    { "id": "transmission", "name": "Transmission", "paths": ["${CACHE}/transmission"] },
    { "id": "audacious", "name": "Audacious", "paths": ["${CACHE}/audacious"] },
    { "id": "rhythmbox", "name": "Rhythmbox", "paths": ["${CACHE}/rhythmbox"] },
    { "id": "wine", "name": "Wine", "paths": ["${HOME}/.wine/drive_c/windows/temp"] },
    { "id": "android-studio", "name": "Android Studio", "paths": ["${CACHE}/Google"], "description": "Android Studio IDE caches (regenerated on restart)" },
    { "id": "conda", "name": "Conda Package Cache", "paths": ["${HOME}/anaconda3/pkgs", "${HOME}/miniconda3/pkgs", "${HOME}/.conda/pkgs"], "description": "Conda downloaded package cache (conda clean --packages clears this)" },
    { "id": "unity", "name": "Unity Editor", "paths": ["${CACHE}/unity3d"], "description": "Unity global shader and GI cache (regenerated when projects are opened)" },
    { "id": "notion", "name": "Notion", "paths": ["${CONFIG}/Notion/Cache/Cache_Data"] },
    { "id": "obsidian", "name": "Obsidian", "paths": ["${CONFIG}/obsidian/Cache/Cache_Data"] },
    { "id": "whatsapp", "name": "WhatsApp Desktop", "paths": ["${CONFIG}/WhatsApp/Cache/Cache_Data"] },
    { "id": "bitwarden", "name": "Bitwarden", "paths": ["${CONFIG}/Bitwarden/Cache/Cache_Data"] },
    { "id": "1password", "name": "1Password", "paths": ["${CONFIG}/1Password/Cache/Cache_Data"] },
    { "id": "ruby-gems", "name": "Ruby Gem Cache", "paths": ["${HOME}/.gem"], "childSubdir": "cache", "description": "Downloaded .gem file cache (reinstall regenerates as needed)" },
    { "id": "deno", "name": "Deno Cache", "paths": ["${CACHE}/deno"], "description": "Deno module cache (re-downloaded on demand)" }
  ]
}
