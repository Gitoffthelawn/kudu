{
  "$schema": "../schema/rules.schema.json",
  "type": "apps",
  "apps": [
    { "id": "discord", "name": "Discord", "paths": ["${APP_SUPPORT}/discord/Cache/Cache_Data"] },
    { "id": "vscode", "name": "VS Code", "paths": ["${APP_SUPPORT}/Code/Cache/Cache_Data", "${APP_SUPPORT}/Code/CachedData"] },
    { "id": "slack", "name": "Slack", "paths": ["${APP_SUPPORT}/Slack/Cache/Cache_Data"] },
    { "id": "teams", "name": "Microsoft Teams", "paths": ["${APP_SUPPORT}/Microsoft Teams/Cache"] },
    { "id": "spotify", "name": "Spotify", "paths": ["${CACHES}/com.spotify.client"] },
    { "id": "npm", "name": "npm Cache", "paths": ["${HOME}/.npm/_cacache"] },
    { "id": "yarn", "name": "Yarn Cache", "paths": ["${CACHES}/Yarn"] },
    { "id": "pip", "name": "pip Cache", "paths": ["${CACHES}/pip"] },
    { "id": "homebrew", "name": "Homebrew Cache", "paths": ["${CACHES}/Homebrew"] },
    { "id": "zoom", "name": "Zoom", "paths": ["${APP_SUPPORT}/zoom.us/data/Cache", "${APP_SUPPORT}/zoom.us/data/GPUCache", "${APP_SUPPORT}/zoom.us/data/logs", "${LIBRARY}/Logs/zoom.us"] },
    { "id": "telegram", "name": "Telegram", "paths": ["${APP_SUPPORT}/Telegram Desktop/tdata/user_data", "${APP_SUPPORT}/Telegram Desktop/tdata/emoji"] },
    { "id": "obs", "name": "OBS Studio", "paths": ["${APP_SUPPORT}/obs-studio/logs", "${APP_SUPPORT}/obs-studio/profiler_data"] },
    { "id": "jetbrains", "name": "JetBrains IDEs", "paths": ["${CACHES}/JetBrains"] },
    { "id": "adobe", "name": "Adobe Creative Cloud", "paths": ["${CACHES}/Adobe", "${APP_SUPPORT}/Adobe/Common/Media Cache Files", "${APP_SUPPORT}/Adobe/Common/Media Cache"] },
    { "id": "pnpm", "name": "pnpm Store", "paths": ["${LIBRARY}/pnpm/store"] },
    { "id": "bun", "name": "Bun Cache", "paths": ["${HOME}/.bun/install/cache"] },
    { "id": "cargo", "name": "Cargo/Rust Cache", "paths": ["${HOME}/.cargo/registry/cache", "${HOME}/.cargo/registry/src"] },
    { "id": "go", "name": "Go Module Cache", "paths": ["${HOME}/go/pkg/mod/cache"] },
    { "id": "gradle", "name": "Gradle Cache", "paths": ["${HOME}/.gradle/caches", "${HOME}/.gradle/daemon"] },
    { "id": "maven", "name": "Maven Cache", "paths": ["${HOME}/.m2/repository"] },
    { "id": "composer", "name": "Composer Cache", "paths": ["${CACHES}/composer"] },
    { "id": "cursor", "name": "Cursor IDE", "paths": ["${APP_SUPPORT}/Cursor/Cache/Cache_Data", "${APP_SUPPORT}/Cursor/CachedData"] },
    { "id": "signal", "name": "Signal Desktop", "paths": ["${APP_SUPPORT}/Signal/Cache/Cache_Data"] },
    { "id": "postman", "name": "Postman", "paths": ["${APP_SUPPORT}/Postman/Cache/Cache_Data"] },
    { "id": "figma", "name": "Figma", "paths": ["${APP_SUPPORT}/Figma/Cache/Cache_Data"] },
    { "id": "github-desktop", "name": "GitHub Desktop", "paths": ["${APP_SUPPORT}/GitHub Desktop/Cache/Cache_Data"] },
    { "id": "vlc", "name": "VLC", "paths": ["${CACHES}/org.videolan.vlc"] },
    { "id": "thunderbird", "name": "Thunderbird", "paths": ["${CACHES}/Thunderbird/Profiles"], "childSubdir": "cache2" },
    { "id": "gimp", "name": "GIMP", "paths": ["${CACHES}/org.gimp.gimp-2.10", "${CACHES}/org.gimp.gimp-2.99", "${CACHES}/org.gimp.gimp-3.0"] },
    { "id": "blender", "name": "Blender", "paths": ["${APP_SUPPORT}/Blender"], "childSubdir": "cache" },
    { "id": "libreoffice", "name": "LibreOffice", "paths": ["${CACHES}/LibreOffice"] },
    { "id": "teamviewer", "name": "TeamViewer", "paths": ["${CACHES}/com.teamviewer.TeamViewer", "${LIBRARY}/Logs/TeamViewer"] },
    { "id": "google-earth", "name": "Google Earth", "paths": ["${CACHES}/com.google.GoogleEarthPro", "${CACHES}/com.google.GoogleEarth"] },
    { "id": "inkscape", "name": "Inkscape", "paths": ["${CACHES}/org.inkscape.Inkscape"] },
    { "id": "krita", "name": "Krita", "paths": ["${CACHES}/krita"] },
    { "id": "filezilla", "name": "FileZilla", "paths": ["${CACHES}/FileZilla"] },
    { "id": "transmission", "name": "Transmission", "paths": ["${CACHES}/org.m0k.transmission"] },
    { "id": "android-studio", "name": "Android Studio", "paths": ["${CACHES}/Google"], "description": "Android Studio IDE caches (regenerated on restart)" },
    { "id": "conda", "name": "Conda Package Cache", "paths": ["${HOME}/anaconda3/pkgs", "${HOME}/miniconda3/pkgs", "${HOME}/.conda/pkgs"], "description": "Conda downloaded package cache (conda clean --packages clears this)" },
    { "id": "unity", "name": "Unity Editor", "paths": ["${CACHES}/com.unity3d.UnityEditor"], "description": "Unity global shader and GI cache (regenerated when projects are opened)" },
    { "id": "notion", "name": "Notion", "paths": ["${APP_SUPPORT}/Notion/Cache/Cache_Data"] },
    { "id": "obsidian", "name": "Obsidian", "paths": ["${APP_SUPPORT}/obsidian/Cache/Cache_Data"] },
    { "id": "whatsapp", "name": "WhatsApp Desktop", "paths": ["${APP_SUPPORT}/WhatsApp/Cache/Cache_Data"] },
    { "id": "bitwarden", "name": "Bitwarden", "paths": ["${APP_SUPPORT}/Bitwarden/Cache/Cache_Data"] },
    { "id": "ruby-gems", "name": "Ruby Gem Cache", "paths": ["${HOME}/.gem"], "childSubdir": "cache", "description": "Downloaded .gem file cache (reinstall regenerates as needed)" },
    { "id": "cocoapods", "name": "CocoaPods Cache", "paths": ["${CACHES}/CocoaPods"], "description": "CocoaPods download cache (pod cache clean --all clears this)" },
    { "id": "deno", "name": "Deno Cache", "paths": ["${CACHES}/deno"], "description": "Deno module cache (re-downloaded on demand)" }
  ]
}
