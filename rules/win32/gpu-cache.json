    { "id": "nvidia", "name": "NVIDIA Shader Cache", "paths": ["${LOCALAPPDATA}/NVIDIA/GLCache", "${LOCALAPPDATA}/NVIDIA/DXCache", "${LOCALAPPDATA}/NVIDIA Corporation/NV_Cache", "${PROGRAMDATA}/NVIDIA Corporation/NV_Cache"] },
