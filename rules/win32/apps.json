{
  "$schema": "../schema/rules.schema.json",
  "type": "apps",
  "apps": [
    { "id": "discord", "name": "Discord", "paths": ["${APPDATA}/discord/Cache/Cache_Data", "${APPDATA}/discord/Code Cache", "${APPDATA}/discord/GPUCache"] },
    { "id": "teams", "name": "Microsoft Teams", "paths": ["${APPDATA}/Microsoft/Teams/Cache"] },
    { "id": "slack", "name": "Slack", "paths": ["${APPDATA}/Slack/Cache/Cache_Data", "${APPDATA}/Slack/Code Cache", "${APPDATA}/Slack/GPUCache"] },
    { "id": "zoom", "name": "Zoom", "paths": ["${APPDATA}/Zoom/data/Cache", "${APPDATA}/Zoom/data/GPUCache", "${APPDATA}/Zoom/data/logs", "${APPDATA}/Zoom/logs"] },
    { "id": "telegram", "name": "Telegram", "paths": ["${APPDATA}/Telegram Desktop/tdata/user_data", "${APPDATA}/Telegram Desktop/tdata/emoji"] },
    { "id": "vscode", "name": "VS Code", "paths": ["${APPDATA}/Code/Cache/Cache_Data", "${APPDATA}/Code/CachedData", "${APPDATA}/Code/CachedExtensions", "${APPDATA}/Code/logs"] },
    { "id": "jetbrains", "name": "JetBrains IDEs", "paths": ["${LOCALAPPDATA}/JetBrains"], "childSubdir": "caches" },
    { "id": "spotify", "name": "Spotify", "paths": ["${LOCALAPPDATA}/Spotify/Storage", "${LOCALAPPDATA}/Spotify/Data"] },
    { "id": "obs", "name": "OBS Studio", "paths": ["${APPDATA}/obs-studio/logs", "${APPDATA}/obs-studio/profiler_data"] },
    { "id": "adobe", "name": "Adobe Creative Cloud", "paths": ["${LOCALAPPDATA}/Adobe/AcroCef/Cache", "${APPDATA}/Adobe/Common/Media Cache Files", "${APPDATA}/Adobe/Common/Media Cache"] },
    { "id": "npm", "name": "npm Cache", "paths": ["${APPDATA}/npm-cache"] },
    { "id": "yarn", "name": "Yarn Cache", "paths": ["${LOCALAPPDATA}/Yarn/Cache"] },
    { "id": "pnpm", "name": "pnpm Store", "paths": ["${LOCALAPPDATA}/pnpm-store"] },
    { "id": "bun", "name": "Bun Cache", "paths": ["${LOCALAPPDATA}/.bun/install/cache"] },
    { "id": "pip", "name": "pip Cache", "paths": ["${LOCALAPPDATA}/pip/Cache"] },
    { "id": "nuget", "name": "NuGet Cache", "paths": ["${LOCALAPPDATA}/NuGet/v3-cache", "${LOCALAPPDATA}/NuGet/plugins-cache"] },
    { "id": "cargo", "name": "Cargo/Rust Cache", "paths": ["${HOME}/.cargo/registry/cache", "${HOME}/.cargo/registry/src"] },
    { "id": "go", "name": "Go Module Cache", "paths": ["${HOME}/go/pkg/mod/cache"] },
    { "id": "gradle", "name": "Gradle Cache", "paths": ["${HOME}/.gradle/caches", "${HOME}/.gradle/daemon"] },
    { "id": "maven", "name": "Maven Cache", "paths": ["${HOME}/.m2/repository"] },
    { "id": "composer", "name": "Composer Cache", "paths": ["${LOCALAPPDATA}/Composer/cache"] },
    { "id": "docker", "name": "Docker Desktop", "paths": ["${APPDATA}/Docker Desktop/cache"] },
    { "id": "cursor", "name": "Cursor IDE", "paths": ["${APPDATA}/Cursor/Cache/Cache_Data", "${APPDATA}/Cursor/CachedData", "${APPDATA}/Cursor/CachedExtensions", "${APPDATA}/Cursor/logs"] },
    { "id": "signal", "name": "Signal Desktop", "paths": ["${APPDATA}/Signal/Cache/Cache_Data", "${APPDATA}/Signal/GPUCache"] },
    { "id": "postman", "name": "Postman", "paths": ["${APPDATA}/Postman/Cache/Cache_Data", "${APPDATA}/Postman/GPUCache"] },
    { "id": "figma", "name": "Figma", "paths": ["${APPDATA}/Figma/Cache/Cache_Data", "${APPDATA}/Figma/GPUCache"] },
    { "id": "github-desktop", "name": "GitHub Desktop", "paths": ["${APPDATA}/GitHub Desktop/Cache/Cache_Data", "${APPDATA}/GitHub Desktop/GPUCache"] },
    { "id": "vlc", "name": "VLC", "paths": ["${APPDATA}/vlc/art_cache"] },
    { "id": "thunderbird", "name": "Thunderbird", "paths": ["${LOCALAPPDATA}/Thunderbird/Profiles"], "childSubdir": "cache2" },
    { "id": "gimp", "name": "GIMP", "paths": ["${APPDATA}/GIMP"], "childSubdir": "tmp" },
    { "id": "blender", "name": "Blender", "paths": ["${APPDATA}/Blender Foundation/Blender"], "childSubdir": "cache" },
    { "id": "libreoffice", "name": "LibreOffice", "paths": ["${APPDATA}/LibreOffice"], "childSubdir": "cache" },
    { "id": "teamviewer", "name": "TeamViewer", "paths": ["${APPDATA}/TeamViewer/Logs"] },
    { "id": "google-earth", "name": "Google Earth", "paths": ["${LOCALAPPDATA}/Google/GoogleEarth/Cache"] },
    { "id": "inkscape", "name": "Inkscape", "paths": ["${LOCALAPPDATA}/inkscape/cache"] },
    { "id": "krita", "name": "Krita", "paths": ["${LOCALAPPDATA}/krita/cache"] },
    { "id": "filezilla", "name": "FileZilla", "paths": ["${APPDATA}/FileZilla/cache"] },
    { "id": "pidgin", "name": "Pidgin", "paths": ["${APPDATA}/.purple/icons"] },
    { "id": "transmission", "name": "Transmission", "paths": ["${LOCALAPPDATA}/Transmission/cache"] },
    { "id": "android-studio", "name": "Android Studio", "paths": ["${LOCALAPPDATA}/Google"], "childSubdir": "caches", "description": "Android Studio IDE caches (regenerated on restart)" },
    { "id": "conda", "name": "Conda Package Cache", "paths": ["${HOME}/anaconda3/pkgs", "${HOME}/miniconda3/pkgs", "${HOME}/.conda/pkgs"], "description": "Conda downloaded package cache (conda clean --packages clears this)" },
    { "id": "unity", "name": "Unity Editor", "paths": ["${LOCALAPPDATA}/Unity/cache"], "description": "Unity global shader and GI cache (regenerated when projects are opened)" },
    { "id": "visual-studio", "name": "Visual Studio", "paths": ["${LOCALAPPDATA}/Microsoft/VisualStudio"], "childSubdir": "ComponentModelCache", "description": "Visual Studio MEF component model cache (regenerated on restart)" },
    { "id": "notion", "name": "Notion", "paths": ["${APPDATA}/Notion/Cache/Cache_Data", "${APPDATA}/Notion/Code Cache", "${APPDATA}/Notion/GPUCache"] },
    { "id": "obsidian", "name": "Obsidian", "paths": ["${APPDATA}/obsidian/Cache/Cache_Data", "${APPDATA}/obsidian/Code Cache", "${APPDATA}/obsidian/GPUCache"] },
    { "id": "whatsapp", "name": "WhatsApp Desktop", "paths": ["${APPDATA}/WhatsApp/Cache/Cache_Data", "${APPDATA}/WhatsApp/Code Cache", "${APPDATA}/WhatsApp/GPUCache"] },
    { "id": "bitwarden", "name": "Bitwarden", "paths": ["${APPDATA}/Bitwarden/Cache/Cache_Data", "${APPDATA}/Bitwarden/Code Cache", "${APPDATA}/Bitwarden/GPUCache"] },
    { "id": "1password", "name": "1Password", "paths": ["${APPDATA}/1Password/Cache/Cache_Data", "${APPDATA}/1Password/Code Cache", "${APPDATA}/1Password/GPUCache"] },
    { "id": "ruby-gems", "name": "Ruby Gem Cache", "paths": ["${HOME}/.gem"], "childSubdir": "cache", "description": "Downloaded .gem file cache (reinstall regenerates as needed)" },
    { "id": "deno", "name": "Deno Cache", "paths": ["${LOCALAPPDATA}/deno"], "description": "Deno module cache (re-downloaded on demand)" }
  ]
}
