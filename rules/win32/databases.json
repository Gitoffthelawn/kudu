{
  "$schema": "../schema/rules.schema.json",
  "type": "databases",
  "sharedDbFileSets": {
    "chromium": ["History", "Cookies", "Network/Cookies", "Favicons", "Top Sites", "Web Data", "Shortcuts", "Login Data"],
    "firefox": ["places.sqlite", "cookies.sqlite", "favicons.sqlite", "formhistory.sqlite", "webappsstore.sqlite", "content-prefs.sqlite"]
  },
  "targets": [
    { "label": "Google Chrome", "basePath": "${LOCALAPPDATA}/Google/Chrome/User Data", "dbFiles": "$chromium", "multiProfile": true },
    { "label": "Microsoft Edge", "basePath": "${LOCALAPPDATA}/Microsoft/Edge/User Data", "dbFiles": "$chromium", "multiProfile": true },
    { "label": "Brave", "basePath": "${LOCALAPPDATA}/BraveSoftware/Brave-Browser/User Data", "dbFiles": "$chromium", "multiProfile": true },
    { "label": "Vivaldi", "basePath": "${LOCALAPPDATA}/Vivaldi/User Data", "dbFiles": "$chromium", "multiProfile": true },
    { "label": "Opera", "basePath": "${APPDATA}/Opera Software/Opera Stable", "dbFiles": "$chromium" },
    { "label": "Opera GX", "basePath": "${APPDATA}/Opera Software/Opera GX Stable", "dbFiles": "$chromium" },
    { "label": "Arc", "basePath": "${LOCALAPPDATA}/Arc/User Data", "dbFiles": "$chromium", "multiProfile": true },
    { "label": "Chromium", "basePath": "${LOCALAPPDATA}/Chromium/User Data", "dbFiles": "$chromium", "multiProfile": true },
    { "label": "Firefox", "basePath": "${APPDATA}/Mozilla/Firefox/Profiles", "dbFiles": "$firefox", "multiProfile": true, "profilePattern": ["*.default*", "*.dev-edition*"] },
    { "label": "Discord", "basePath": "${APPDATA}/discord", "dbFiles": ["Network/Cookies"] },
    { "label": "Slack", "basePath": "${APPDATA}/Slack", "dbFiles": ["Network/Cookies"] },
    { "label": "Microsoft Teams", "basePath": "${APPDATA}/Microsoft/Teams", "dbFiles": ["Network/Cookies"] },
    { "label": "VS Code", "basePath": "${APPDATA}/Code", "dbFiles": ["Network/Cookies", "User/globalStorage/state.vscdb"] },
    { "label": "Cursor IDE", "basePath": "${APPDATA}/Cursor", "dbFiles": ["Network/Cookies", "User/globalStorage/state.vscdb"] },
    { "label": "Figma", "basePath": "${APPDATA}/Figma", "dbFiles": ["Network/Cookies"] },
    { "label": "Postman", "basePath": "${APPDATA}/Postman", "dbFiles": ["Network/Cookies"] },
    { "label": "Thunderbird", "basePath": "${APPDATA}/Thunderbird/Profiles", "dbFiles": ["global-messages-db.sqlite", "places.sqlite", "cookies.sqlite"], "multiProfile": true, "profilePattern": ["*.default*"] }
  ]
}
